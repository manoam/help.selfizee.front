# URL du back (proxy Vite la résoudra sur /api/*).
VITE_API_URL=http://host.docker.internal:3001

# Hub Konitys (Module Federation) — fournit HeaderBar et Sidebar partagés.
VITE_PLATEFORM_URL=https://plateform.konitys.fr

# Bypass auth — mettre true pendant la phase pré-prod (NDD HTTPS pas prêt pour Keycloak).
# Quand activé, AuthProvider n'est pas monté et l'admin est accessible sans login.
VITE_AUTH_DISABLED=false

# Keycloak — Selfizee plateformdev (ignoré si VITE_AUTH_DISABLED=true).
VITE_KEYCLOAK_URL=https://plateformdev-auth.orkessi.com
VITE_KEYCLOAK_REALM=konitys
VITE_KEYCLOAK_CLIENT_ID=helpselfizee
